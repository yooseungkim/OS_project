set nocompatible            " 호환 모드 해제
set number                  " 줄 번호
set relativenumber          " 상대 번호
set tabstop=4               " Tab=4 space
set shiftwidth=4
set expandtab               " Tab 대신 space
set autoindent
set smartindent
set backspace=indent,eol,start

set clipboard=unnamedplus   " 시스템 클립보드 공유
set undofile                " undo 기록 유지

set ignorecase
set smartcase
set hlsearch
set incsearch



set laststatus=2
set showcmd
set noshowmode              " airline이 모드 표시하므로 끔

